# --- External Service Configuration ---
EXTERNAL_SERVICE_URL=http://external-mock-service:5001/external-api/process

# --- Rate Limiter Configuration ---
# The time window in seconds for tracking client requests
RATE_LIMIT_WINDOW_SECONDS=60
# The maximum number of allowed requests per client within the window
RATE_LIMIT_MAX_REQUESTS=10

# --- Circuit Breaker Configuration ---
# The number of consecutive external service failures before tripping the circuit
CB_FAILURE_THRESHOLD=5
# Time in seconds the circuit remains OPEN before transitioning to HALF-OPEN
CB_RESET_TIMEOUT_SECONDS=30

# --- Retry Strategy Configuration ---
# Maximum number of retry attempts for a single request
RETRY_MAX_ATTEMPTS=3
# The initial delay in milliseconds before the first retry
RETRY_INITIAL_DELAY_MS=100
# The multiplier for exponential backoff (e.g., 2 = 100ms, 200ms, 400ms)
RETRY_BACKOFF_MULTIPLIER=2
